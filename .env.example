# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario@localhost:5432/mimundoazul?schema=public"

# JWT (cambiar a un secreto fuerte en producción)
JWT_SECRET="cambiar-en-produccion"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001

# CORS — URLs de las apps que consumen la API
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# Carpeta donde se guardan las imágenes subidas
UPLOAD_DIR="./uploads"
